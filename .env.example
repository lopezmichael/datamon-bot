# ==========================================
# Datamon Bot — Environment Variables
# ==========================================
# Copy this file to .env and fill in all values.
# All Discord IDs are numeric snowflakes (right-click → Copy ID with Developer Mode on).

# ------------------------------------------
# Discord Bot
# ------------------------------------------
# Bot token from Discord Developer Portal → Bot → Reset Token
DISCORD_BOT_TOKEN=

# Server (guild) ID — right-click server name → Copy Server ID
DISCORD_GUILD_ID=

# ------------------------------------------
# Discord Role IDs
# ------------------------------------------
# Right-click each role in Server Settings → Roles → Copy Role ID
DISCORD_ROLE_PLATFORM_ADMIN=
DISCORD_ROLE_REGIONAL_ADMIN=
DISCORD_ROLE_SCENE_ADMIN=

# ------------------------------------------
# Discord Channel IDs
# ------------------------------------------
# Right-click channel → Copy Channel ID
DISCORD_CHANNEL_SCENE_COORDINATION=
DISCORD_CHANNEL_SCENE_REQUESTS=
DISCORD_CHANNEL_BUG_REPORTS=
DISCORD_CHANNEL_FEATURE_REQUESTS=

# ------------------------------------------
# Discord Forum Tag IDs
# ------------------------------------------
# Tags the bot ADDS to threads. Use the API to get tag IDs (see README).
# Existing tags (continent, request type) are preserved automatically at runtime.
#
# #scene-coordination — added when request resolved via reaction
DISCORD_TAG_RESOLVED=
# #scene-requests — added when scene request completed via reaction
DISCORD_TAG_ONBOARDED=
# #bug-reports — added when bug fixed via reaction
DISCORD_TAG_FIXED=
# #feature-requests — added when feature shipped via reaction
DISCORD_TAG_SHIPPED=

# ------------------------------------------
# Discord Webhook URLs
# ------------------------------------------
# Server Settings → Integrations → Webhooks → Copy Webhook URL
DISCORD_WEBHOOK_BOT_LOG=

# ------------------------------------------
# Neon PostgreSQL (same instance as digilab-app)
# ------------------------------------------
NEON_HOST=
NEON_DATABASE=
NEON_USER=
NEON_PASSWORD=
